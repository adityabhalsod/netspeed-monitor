<?xml version="1.0" encoding="utf-8"?>
<!-- Warning banner background: rounded corners with warm tint, adapts to dark mode -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/warning_bg" />
    <corners android:radius="12dp" />
    <stroke android:width="1dp" android:color="@color/warning_border" />
</shape>
