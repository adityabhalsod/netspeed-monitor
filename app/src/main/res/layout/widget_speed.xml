<?xml version="1.0" encoding="utf-8"?>
<!-- Home screen widget layout: live speed + today's data usage summary -->
<!-- Uses only RemoteViews-compatible views: LinearLayout, TextView, ImageView -->
<!-- All colors use @color/ refs so Android auto-switches between light/dark mode -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_widget"
    android:padding="14dp">

    <!-- Header row: app name + status indicator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <!-- App name label -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Net Speed"
            android:textColor="@color/widget_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Live monitoring status pill -->
        <TextView
            android:id="@+id/widget_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stopped"
            android:textColor="@color/widget_status_stopped"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Live speed section: expands to fill ~55% of remaining height -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="55"
        android:orientation="horizontal"
        android:background="@drawable/bg_widget_section"
        android:padding="12dp"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <!-- Download speed column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Download arrow label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\u2193 Download"
                android:textColor="@color/widget_text_muted"
                android:textSize="13sp" />

            <!-- Download speed value -->
            <TextView
                android:id="@+id/widget_download_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 B/s"
                android:textColor="@color/download_green"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Vertical divider (TextView for RemoteViews compatibility) -->
        <TextView
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/widget_divider" />

        <!-- Upload speed column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Upload arrow label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\u2191 Upload"
                android:textColor="@color/widget_text_muted"
                android:textSize="13sp" />

            <!-- Upload speed value -->
            <TextView
                android:id="@+id/widget_upload_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 B/s"
                android:textColor="@color/upload_orange"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Today's data usage section: expands to fill ~45% of remaining height -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="45"
        android:orientation="vertical"
        android:background="@drawable/bg_widget_section"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Section label -->

        <!-- Usage breakdown row: WiFi | Mobile | Total -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="Today\u0027s Usage"
            android:textColor="@color/widget_text_secondary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- WiFi usage column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <!-- WiFi label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WiFi"
                    android:textColor="@color/widget_wifi"
                    android:textSize="14sp" />

                <!-- WiFi usage value -->
                <TextView
                    android:id="@+id/widget_wifi_usage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 B"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Mobile usage column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <!-- Mobile label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mobile"
                    android:textColor="@color/widget_mobile"
                    android:textSize="14sp" />

                <!-- Mobile usage value -->
                <TextView
                    android:id="@+id/widget_mobile_usage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 B"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Total usage column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <!-- Total label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total"
                    android:textColor="@color/widget_total"
                    android:textSize="14sp" />

                <!-- Total usage value -->
                <TextView
                    android:id="@+id/widget_total_usage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 B"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="21sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
