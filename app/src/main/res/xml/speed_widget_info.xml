<?xml version="1.0" encoding="utf-8"?>
<!-- Widget configuration metadata for SpeedWidgetProvider -->
<!-- Defines size, update interval, layout, and appearance for the home screen widget -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="180dp"
    android:maxResizeWidth="530dp"
    android:maxResizeHeight="280dp"
    android:targetCellWidth="4"
    android:targetCellHeight="3"
    android:updatePeriodMillis="1800000"
    android:initialLayout="@layout/widget_speed"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:previewImage="@mipmap/ic_launcher"
    android:description="@string/widget_description" />
