<?xml version="1.0" encoding="utf-8"?>
<!-- Lightweight manifest: pure Java components, no AndroidX, no Compose -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permission to access network state information -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Permission to run foreground services -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Foreground service type for data sync monitoring (API 34+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Permission to receive boot completed broadcast for auto-start -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Permission to post notifications (required on Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Permission to query per-app network usage stats via NetworkStatsManager -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        android:maxSdkVersion="999" />

    <application
        android:name=".NetSpeedApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.NetSpeedMonitor">

        <!-- Main Activity: dashboard with speed gauges and toggle -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Settings Activity: start-on-boot toggle -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false" />

        <!-- Foreground service for persistent network speed monitoring -->
        <service
            android:name=".SpeedMonitorService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Boot receiver: restarts monitoring service after device reboot -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- Home screen widget: live speed + today's data usage -->
        <receiver
            android:name=".SpeedWidgetProvider"
            android:exported="true">
            <intent-filter>
                <!-- Standard widget update action -->
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <!-- Custom live speed update action from SpeedMonitorService -->
                <action android:name="com.netspeed.monitor.action.WIDGET_SPEED_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/speed_widget_info" />
        </receiver>

    </application>

</manifest>
